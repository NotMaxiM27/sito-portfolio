---
import { ClientRouter } from 'astro:transitions';
import { getCollection } from 'astro:content';
import CrtOverlay from '../components/ui/CrtOverlay';
import ProjectGrid from '../components/ui/ProjectGrid';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const allProjects = await getCollection('projects');
const progettiData = allProjects
  .sort((a, b) => (a.data.order || 99) - (b.data.order || 99))
  .map(p => ({
    id: p.data.id,
    title: p.data.title,
    tags: p.data.tags,
    image: p.data.image,
  }));
---

<html lang="it">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={import.meta.env.BASE_URL + "favicon.svg"} />
    <meta name="viewport" content="width=device-width" />
    <title>Portfolio | Samuel Uscidda</title>
    <ClientRouter />
  </head>
  <body class="relative min-h-screen text-white bg-black overflow-x-hidden">
    
    {/* CSS Vaporwave Sunset Background */}
    <div class="fixed inset-0 z-0 pointer-events-none overflow-hidden vaporwave-bg" style="perspective: 1000px;">
      
      {/* Sun */}
      <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 vaporwave-sun"></div>

      {/* Grid */}
      <div class="synthwave-grid"></div>

      {/* Horizon glow */}
      <div class="absolute left-0 top-1/2 w-full h-32 bg-gradient-to-b from-[#ff0055]/30 to-transparent -translate-y-1/2"></div>
    </div>

    <Header />

    <main class="relative z-10 flex flex-col items-center pt-10 pb-20 flex-grow">
      <ProjectGrid client:load progetti={progettiData} />
    </main>

    <Footer />

    <CrtOverlay />

  </body>
</html>