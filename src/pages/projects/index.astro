---
import { ClientRouter } from 'astro:transitions';
import { getCollection } from 'astro:content';
import Navbar from '../../components/ui/Navbar';
import CrtOverlay from '../../components/ui/CrtOverlay';
import ProjectGrid from '../../components/ui/ProjectGrid';
import '../../styles/global.css';

const allProjects = await getCollection('projects');
const progettiData = allProjects
  .sort((a, b) => (a.data.order || 99) - (b.data.order || 99))
  .map(p => ({
    id: p.data.id,
    title: p.data.title,
    tags: p.data.tags,
    image: p.data.image,
  }));
---

<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Projects | Portfolio</title>
    <ClientRouter />
  </head>
  <body class="relative min-h-screen text-white bg-[#050505] overflow-x-hidden">
    
    <Navbar client:load transition:persist="navbar" />

    <main class="relative z-10 flex flex-col items-center pt-32 pb-20">
      <h1 class="text-5xl font-black mb-10 pixel-text text-glitch text-center">
        PROJECT_ARCHIVE
      </h1>
      <p class="text-gray-400 mb-8 pixel-text text-sm text-center">
        > SELEZIONA UN MODULO PER INIZIALIZZARE L'ANTEPRIMA_
      </p>
      
      <ProjectGrid client:load progetti={progettiData} />
    </main>

    <CrtOverlay />
  </body>
</html>