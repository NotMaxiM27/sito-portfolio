---
// Header.astro
---

<header class="w-full py-6 flex justify-center items-center z-40 relative">
  <div class="vaporwave-container">
    <h1 class="vaporwave-text tracking-widest uppercase">SAMUEL USCIDDA</h1>
    <div class="scanlines"></div>
  </div>
</header>

<style>
  .vaporwave-container {
    position: relative;
    display: inline-block;
  }

  .vaporwave-text {
    font-size: 3rem;
    font-weight: 900;
    font-family: monospace;
    color: #fff;
    text-shadow: 
      3px 3px 0px #0ff, 
      -3px -3px 0px #f0f;
    position: relative;
    z-index: 2;
    animation: glitch-anim 3s infinite linear alternate-reverse;
  }

  @keyframes glitch-anim {
    0% { text-shadow: 3px 3px 0px #0ff, -3px -3px 0px #f0f; }
    20% { text-shadow: -3px -3px 0px #0ff, 3px 3px 0px #f0f; }
    40% { text-shadow: 2px -2px 0px #0ff, -2px 2px 0px #f0f; }
    60% { text-shadow: -2px 3px 0px #0ff, 2px -3px 0px #f0f; }
    80% { text-shadow: 3px 2px 0px #0ff, -3px -2px 0px #f0f; }
    100% { text-shadow: -3px 2px 0px #0ff, 3px -2px 0px #f0f; }
  }

  .scanlines {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(255,255,255,0),
      rgba(255,255,255,0) 50%,
      rgba(0,0,0,0.3) 50%,
      rgba(0,0,0,0.3)
    );
    background-size: 100% 6px;
    z-index: 3;
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .vaporwave-text {
      font-size: 2rem;
    }
  }
</style>
